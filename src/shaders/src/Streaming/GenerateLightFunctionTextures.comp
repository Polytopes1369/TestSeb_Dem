#version 460
#extension GL_GOOGLE_include_directive : enable

// F12 (UE5.8 rendering-parity gap: Texture-based Light Functions + projected Caustics) -- procedurally
// generates every slot of renderer::ProceduralLightFunctionGenerator's texture set: zero image assets,
// matching the project's "100% procedural, no data in the exe" rule (CLAUDE.md). Mirrors
// ProceduralMaskGenerate.comp's own "one dispatch, Z-slice per slot, uniform gl_GlobalInvocationID.z
// indexing (no nonuniformEXT needed here at GENERATION time -- unlike the per-pixel-varying SAMPLING
// indices light_functions.glsl's own EvaluateLightFunction()/caustics_projection.glsl's
// ComputeCausticsModulation() use)" shape exactly.
//
// K_LIGHT_FUNCTION_SLOT_COUNT (4) real texture-based Light Function gobo patterns (slots 0-3) +
// exactly 1 caustics pattern (slot 4, K_CAUSTICS_SLOT) share ONE dispatch/descriptor/image array --
// see renderer::ProceduralLightFunctionGenerator's own class comment for why: both are "one-shot,
// startup-only, small procedural pattern texture" generation with an identical Vulkan resource
// lifecycle, so splitting them into two separate generator classes/shaders would only duplicate this
// file's own boilerplate for no benefit. The CPU side slices the resulting VkDescriptorImageInfo
// array into GetLightFunctionImageInfos() (slots 0..3, bound to light_functions.glsl's own bindless
// g_LightFunctionTextures[]) and GetCausticsImageInfo() (slot 4 alone, bound to
// caustics_projection.glsl's own single g_CausticsTexture).

#define K_LIGHT_FUNCTION_TEXTURE_SIZE 256u
#define K_LIGHT_FUNCTION_SLOT_COUNT 4u
#define K_CAUSTICS_SLOT 4u
#define K_TOTAL_SLOTS 5u
#include "include/hash_utils.glsl"

layout(rgba8, set = 0, binding = 0) uniform writeonly image2D g_Outputs[K_TOTAL_SLOTS];

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

const float kPI = 3.14159265358979323846;

// Same bilinearly-interpolated hashed value-noise ProceduralMaskGenerate.comp already established
// (reproduced here rather than shared -- this codebase's own "duplicate small per-shader generation
// helpers" convention, see megalights_ris.glsl's own header comment for the identical rationale
// applied to shading-time functions instead of generation-time ones).
float ValueNoise(vec2 p, uint slot) {
    vec2 cell = floor(p);
    vec2 frac = p - cell;
    vec2 smoothFrac = frac * frac * (3.0 - 2.0 * frac);

    uint ix = uint(cell.x), iy = uint(cell.y);
    float h00 = float(HashUint(ix * 1973u + iy * 9277u + slot * 26699u) & 0xFFFFu) / 65535.0;
    float h10 = float(HashUint((ix + 1u) * 1973u + iy * 9277u + slot * 26699u) & 0xFFFFu) / 65535.0;
    float h01 = float(HashUint(ix * 1973u + (iy + 1u) * 9277u + slot * 26699u) & 0xFFFFu) / 65535.0;
    float h11 = float(HashUint((ix + 1u) * 1973u + (iy + 1u) * 9277u + slot * 26699u) & 0xFFFFu) / 65535.0;

    float top = mix(h00, h10, smoothFrac.x);
    float bottom = mix(h01, h11, smoothFrac.x);
    return mix(top, bottom, smoothFrac.y);
}

// Slot 0: radial sunburst / crepuscular-ray gobo -- concentric angular rays from the texture center,
// the classic "light shining through a slotted gobo wheel" architectural light-function look (UE5.8's
// own most common Light Function use case for a spot/directional key light).
vec3 PatternSunburst(vec2 uv) {
    vec2 centered = uv - vec2(0.5);
    float angle = atan(centered.y, centered.x);
    float dist = length(centered) * 2.0;
    const float kRayCount = 20.0;
    float rays = sin(angle * kRayCount) * 0.5 + 0.5;
    rays = pow(rays, 2.5);
    // Softly fade the rays out toward the texture edge and brighten toward center -- a gobo wheel's
    // rays converge to a point, they don't stay full-contrast all the way to the rim.
    float radialFade = 1.0 - smoothstep(0.0, 1.0, dist);
    float v = mix(0.15, 1.0, rays * radialFade + (1.0 - radialFade) * 0.15);
    return vec3(v);
}

// Slot 1: venetian-blind bars -- alternating horizontal light/dark bands, the other classic
// architectural Light Function look (light through window blinds/louvers).
vec3 PatternVenetianBlinds(vec2 uv) {
    const float kBarCount = 14.0;
    float bar = fract(uv.y * kBarCount);
    float v = smoothstep(0.0, 0.12, bar) * (1.0 - smoothstep(0.82, 1.0, bar));
    // Never fully zero -- a real blind still lets some ambient bounce through the gaps, and a
    // hard 0 would read as a flicker-prone binary cutout rather than a soft light modulation.
    return vec3(mix(0.08, 1.0, v));
}

// Slot 2: soft radial spot mask -- a smooth circular falloff from center, for a focused hanging-lamp
// look (softer-edged than PatternSunburst's own harder rays, useful on a light whose gobo should read
// as "a soft pool of light" rather than a patterned cutout).
vec3 PatternSoftSpot(vec2 uv) {
    float dist = length(uv - vec2(0.5)) * 2.0;
    float v = 1.0 - smoothstep(0.35, 1.0, dist);
    return vec3(v);
}

// Slot 3: dappled/foliage-shadow noise -- two octaves of hashed value noise thresholded softly,
// mimicking sunlight filtering through leaves/foliage (UE5.8's own "TreeCanopy" Light Function
// showcase use case).
vec3 PatternDappled(vec2 uv, uint slot) {
    float n = ValueNoise(uv * 5.0, slot) * 0.65 + ValueNoise(uv * 11.0, slot) * 0.35;
    float v = smoothstep(0.30, 0.65, n);
    return vec3(mix(0.20, 1.0, v));
}

// Slot 4 (K_CAUSTICS_SLOT): tileable procedural caustics -- three octaves of PERIODIC sine
// interference (integer-cycle frequencies across [0,1] UV, unlike procedural_light_modulation.glsl's
// own EvaluateSunLightFunction/ComputeUnderwaterCaustics analytic per-pixel formulas, which never
// needed to tile since they sampled world position directly, not a wrapped texture) -- bright,
// sharp-edged cell boundaries are the well-known signature of real underwater light caustics
// (focused/defocused refraction through a wavy surface). caustics_projection.glsl's own
// ComputeCausticsModulation() scrolls the SAMPLING uv over time (g_Caustics.causticsAnimation), so
// this baked texture only needs to tile seamlessly, not animate itself.
vec3 PatternCaustics(vec2 uv) {
    vec2 p = uv * 2.0 * kPI;
    float pattern = sin(p.x * 3.0) * cos(p.y * 3.0) * 0.5
                   + sin(p.y * 5.0 + p.x * 2.0) * cos(p.x * 4.0 - p.y * 2.0) * 0.3
                   + sin((p.x + p.y) * 6.0) * cos((p.x - p.y) * 5.0) * 0.2;
    pattern = pattern * 0.5 + 0.5;
    pattern = pow(pattern, 2.2); // Sharpen toward bright, thin caustic cell boundaries.
    // A faint cyan-white tint (real underwater caustics are never pure grayscale -- they carry the
    // water's own blue-green absorption bias) rather than a flat luminance pattern.
    return mix(vec3(0.75, 0.90, 1.0), vec3(1.0), pattern) * pattern;
}

void main() {
    uint slot = gl_GlobalInvocationID.z;
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    if (pixel.x >= int(K_LIGHT_FUNCTION_TEXTURE_SIZE) || pixel.y >= int(K_LIGHT_FUNCTION_TEXTURE_SIZE) || slot >= K_TOTAL_SLOTS) {
        return;
    }

    vec2 uv = vec2(pixel) / float(K_LIGHT_FUNCTION_TEXTURE_SIZE);

    vec3 color;
    if (slot == 0u)      color = PatternSunburst(uv);
    else if (slot == 1u) color = PatternVenetianBlinds(uv);
    else if (slot == 2u) color = PatternSoftSpot(uv);
    else if (slot == 3u) color = PatternDappled(uv, slot);
    else                 color = PatternCaustics(uv); // slot == K_CAUSTICS_SLOT

    imageStore(g_Outputs[slot], pixel, vec4(color, 1.0));
}
