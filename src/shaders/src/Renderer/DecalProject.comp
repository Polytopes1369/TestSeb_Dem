#version 460
#extension GL_GOOGLE_include_directive : enable

// UE5.8-parity gap G1 (Decal system): deferred projected-decal compositing. One invocation per
// output pixel. Runs immediately after renderer::ClusterResolvePass has written the GBuffer + the
// direct sun-lit color (cmdMid), and BEFORE any of the deferred lighting passes that consume the
// GBuffer this frame (GTAO / Contact Shadows / Reflections / MegaLights / GI Composite) -- exactly a
// UE deferred decal's "written into the GBuffer before it is consumed by lighting" placement.
//
// For each pixel this shader:
//   1. Reconstructs the pixel's world position from the GBuffer depth (the SAME invViewProj * clip
//      convention ReflectionGather.comp / GIComposite.comp already use -- not a second reconstruction
//      formula), rejecting background (reversed-Z far == 0).
//   2. Traverses a CPU-built decal BVH (geometry::DecalBVH, the same flattened 32-byte-node layout as
//      the entity / MegaLights BVHs) to find only the handful of decal boxes whose world AABB
//      contains this point, instead of testing every decal per pixel.
//   3. For every decal whose oriented box actually contains the point (worldToDecal maps it inside the
//      unit cube), evaluates a fully-procedural (noise-only, zero-texture) material patch and inserts
//      it into a small per-pixel list sorted ascending by sortPriority.
//   4. Folds the sorted decals over the base surface (higher priority wins overlaps -- UE decal sort
//      order), producing a blended albedo / roughness / metallic / normal / emissive.
//
// It then writes the result two ways, deliberately:
//   * GBUFFER: the blended albedo / roughness-metallic / (crack-)perturbed normal are written back
//     into renderer::ClusterResolvePass's GBuffer images, so every deferred lighting pass downstream
//     THIS frame sees the decal surface (this is the literal "blended into the GBuffer" behavior).
//   * DIRECT COLOR: because the resolve pass already baked this frame's sun/shadow/ambient lighting
//     into the color image using the UNDECALED albedo, the decal is composited into that color via
//     ALBEDO DE-MODULATION -- illum = color / origAlbedo recovers the incoming light * diffuse-BRDF
//     that actually hit the surface (inheriting the sun NdotL, the Virtual Shadow Map shadow, and the
//     ambient term for free), then illum * decalAlbedo re-lights it with the decal color. Where a
//     pixel is uncovered, decalAlbedo == origAlbedo so the color is reproduced exactly. This is why
//     the showcase decals are authored onto matte DIELECTRIC surfaces (floor, Cornell walls): there
//     origAlbedo is well above the clamp floor and diffuse dominates, so de-modulation is accurate.
//     (Known, documented approximation: any specular already baked into the color is scaled by the
//     albedo ratio too, and the additive point-light/reflection passes re-fetch the UNDECALED
//     material by materialID -- both negligible for the matte diffuse surfaces decals target here.)

#include "include/octahedral.glsl"
#include "include/decal_common.glsl"

layout(local_size_x = 8, local_size_y = 8) in;

// GBuffer (all renderer::ClusterResolvePass outputs, kept in VK_IMAGE_LAYOUT_GENERAL for their whole
// lifetime -- same storage-image convention every other GI pass binds them with).
layout(r32f,  set = 0, binding = 0) uniform readonly image2D g_GBufferDepth;             // Winning NDC depth (reversed-Z; 0 == background).
layout(rg16f, set = 0, binding = 1) uniform image2D g_GBufferNormal;                     // Octahedral world normal (read-modify-write).
layout(rgba8, set = 0, binding = 2) uniform image2D g_GBufferAlbedo;                     // Base color pre-lighting (read-modify-write).
layout(rg8,   set = 0, binding = 3) uniform image2D g_GBufferRoughnessMetallic;          // R=roughness,G=metallic (read-modify-write).
layout(rgba16f, set = 0, binding = 4) uniform image2D g_OutputColor;                     // Direct-lit HDR color (read-modify-write).

layout(std140, set = 0, binding = 5) uniform DecalViewParamsUBO {
    mat4 invViewProj;
    vec2 viewportSize;
    uint decalCount;
    uint debugShowBounds;   // Debug-only; always 0 in Release (the code that reads it is #ifdef _DEBUG-gated below).
    vec3 cameraPositionWorld;
    float timeSeconds;
} g_View;

layout(std430, set = 0, binding = 6) readonly buffer DecalSSBO {
    DecalInstance decals[];
} g_Decals;

layout(std430, set = 0, binding = 7) readonly buffer DecalBVHNodesSSBO {
    DecalBVHNode nodes[];
} g_Nodes;

layout(std430, set = 0, binding = 8) readonly buffer DecalIndicesSSBO {
    uint indices[];
} g_Indices;

// Small per-pixel cap on simultaneously-composited decals -- comfortably above any realistic overlap
// depth (the showcase set overlaps 2 deep at most). Extra candidates beyond this keep only the
// highest-priority ones (the ones that would win the fold anyway).
const int kMaxDecalHits = 8;
// BVH is tiny (a handful of decals); this depth cannot be exceeded, but the guard is kept for safety.
const int kBVHStackSize = 32;

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    if (pixel.x >= int(g_View.viewportSize.x) || pixel.y >= int(g_View.viewportSize.y)) {
        return;
    }
    if (g_View.decalCount == 0u) {
        return;
    }

    float depth = imageLoad(g_GBufferDepth, pixel).r;
    if (depth <= 0.0) {
        return; // Sky/background (reversed-Z: 0.0 == far sentinel).
    }

    // Reconstruct world position (identical convention to ReflectionGather.comp / GIComposite.comp).
    vec2 ndcXY = ((vec2(pixel) + 0.5) / g_View.viewportSize) * 2.0 - 1.0;
    vec4 worldPos4 = g_View.invViewProj * vec4(ndcXY, depth, 1.0);
    vec3 worldPos = worldPos4.xyz / worldPos4.w;

    vec3 surfaceNormal = OctDecode(imageLoad(g_GBufferNormal, pixel).rg);

    // -------------------------------------------------------------------------------------------
    // Gather covering decals via a stack-based BVH walk, insertion-sorted ASCENDING by sortPriority.
    // -------------------------------------------------------------------------------------------
    uint  hitIndex[kMaxDecalHits];
    float hitPriority[kMaxDecalHits];
    int   hitCount = 0;

    int stack[kBVHStackSize];
    int sp = 0;
    stack[sp++] = 0; // Root.

    while (sp > 0) {
        int ni = stack[--sp];
        DecalBVHNode node = g_Nodes.nodes[ni];

        // AABB rejection against the reconstructed world position (array-form node fields, matching
        // megalights_bvh.glsl's own reconstruction convention).
        vec3 bmin = vec3(node.boundsMin[0], node.boundsMin[1], node.boundsMin[2]);
        vec3 bmax = vec3(node.boundsMax[0], node.boundsMax[1], node.boundsMax[2]);
        if (worldPos.x < bmin.x || worldPos.y < bmin.y || worldPos.z < bmin.z ||
            worldPos.x > bmax.x || worldPos.y > bmax.y || worldPos.z > bmax.z) {
            continue;
        }

        if (node.count > 0) {
            // Leaf: test each decal's oriented box for exact containment.
            for (int i = 0; i < node.count; ++i) {
                uint di = g_Indices.indices[node.leftFirst + i];
                vec3 lc = (g_Decals.decals[di].worldToDecal * vec4(worldPos, 1.0)).xyz;
                if (all(lessThanEqual(abs(lc), vec3(1.0)))) {
                    float pri = g_Decals.decals[di].params.y;
                    // Insertion into the ascending-priority list (drop the lowest if already full).
                    if (hitCount < kMaxDecalHits) {
                        int j = hitCount - 1;
                        while (j >= 0 && hitPriority[j] > pri) {
                            hitPriority[j + 1] = hitPriority[j];
                            hitIndex[j + 1] = hitIndex[j];
                            --j;
                        }
                        hitPriority[j + 1] = pri;
                        hitIndex[j + 1] = di;
                        ++hitCount;
                    } else if (pri > hitPriority[0]) {
                        // Full: evict the current lowest-priority hit (index 0), then insert.
                        int j = 0;
                        while (j < kMaxDecalHits - 1 && hitPriority[j + 1] < pri) {
                            hitPriority[j] = hitPriority[j + 1];
                            hitIndex[j] = hitIndex[j + 1];
                            ++j;
                        }
                        hitPriority[j] = pri;
                        hitIndex[j] = di;
                    }
                }
            }
        } else if (sp <= kBVHStackSize - 2) {
            // Interior node: left child is always ni+1, right child is node.leftFirst (see DecalBVH.h).
            stack[sp++] = ni + 1;
            stack[sp++] = node.leftFirst;
        }
    }

    // -------------------------------------------------------------------------------------------
    // Fold the sorted decals over the base surface (low priority first, high priority last -> wins).
    // -------------------------------------------------------------------------------------------
    vec3  origAlbedo = imageLoad(g_GBufferAlbedo, pixel).rgb;
    vec2  origRM = imageLoad(g_GBufferRoughnessMetallic, pixel).rg;

    vec3  accAlbedo = origAlbedo;
    float accRough = origRM.r;
    float accMetal = origRM.g;
    vec3  accEmissive = vec3(0.0);
    vec3  accNormal = surfaceNormal;
    float totalCoverage = 0.0;

#ifdef _DEBUG
    // Debug bounds overlay: tracks whether this pixel sits near any decal box face (largest local
    // coordinate ~1) so the bounds can be outlined -- see the write block at the end.
    float debugEdgeMax = 0.0;
#endif

    for (int h = 0; h < hitCount; ++h) {
        uint di = hitIndex[h];
        DecalInstance dec = g_Decals.decals[di];

        vec3 lc = (dec.worldToDecal * vec4(worldPos, 1.0)).xyz;
        vec2 uv01 = lc.xy * 0.5 + 0.5;

#ifdef _DEBUG
        debugEdgeMax = max(debugEdgeMax, max(abs(lc.x), max(abs(lc.y), abs(lc.z))));
#endif

        // Two-sided angle fade: decals only apply where the surface is roughly perpendicular to the
        // projection axis. abs() makes it independent of the projection axis's sign (see
        // renderer::MakeDecalInstance -- the box's third axis handedness is not authored per decal).
        float ndotp = abs(dot(surfaceNormal, dec.projAxisWorld.xyz));
        float angleFade = smoothstep(0.20, 0.55, ndotp);
        float edgeFade = DecalEdgeFade(lc.xy, 0.15) * angleFade;
        if (edgeFade <= 0.0) {
            continue;
        }

        uint type = uint(dec.params.x + 0.5);
        float uvScale = dec.axisRightWorld.w;
        float opacity = dec.projAxisWorld.w;
        float emissiveStrength = dec.tint.w;

        DecalSample ds = EvaluateProceduralDecal(type, uv01, worldPos, dec.tint.rgb, uvScale,
                                                 emissiveStrength, edgeFade);
        float c = clamp(ds.coverage * opacity, 0.0, 1.0);
        if (c <= 0.0) {
            continue;
        }

        accAlbedo = mix(accAlbedo, ds.albedo, c);
        accRough = mix(accRough, ds.roughness, c);
        accMetal = mix(accMetal, ds.metallic, c);
        accEmissive += ds.emissive * c;

        // Crack relief bends the GBuffer normal: finite-difference the same crack field along the
        // decal's world-space tangent axes, tilt the normal by the gradient, weighted by the decal's
        // authored normalStrength and its coverage here. Non-crack decals leave normalRelief == 0, so
        // this is a no-op for them.
        if (ds.normalRelief != 0.0) {
            float normalStrength = dec.axisUpWorld.w;
            vec3 tRight = dec.axisRightWorld.xyz;
            vec3 tUp = dec.axisUpWorld.xyz;
            const float eps = 0.03;
            float h0 = DecalCrackField(worldPos, uvScale);
            float hR = DecalCrackField(worldPos + tRight * eps, uvScale);
            float hU = DecalCrackField(worldPos + tUp * eps, uvScale);
            vec2 grad = vec2(hR - h0, hU - h0) / eps;
            vec3 tilt = (tRight * grad.x + tUp * grad.y) * (normalStrength * c);
            accNormal = normalize(accNormal - tilt);
        }

        totalCoverage = totalCoverage + c * (1.0 - totalCoverage);
    }

#ifdef _DEBUG
    // Debug bounds overlay (compiled out entirely in Release, per CLAUDE.md's build-separation rule):
    // outline every decal box the pixel touches, regardless of coverage, so decal placement/extent is
    // directly verifiable. Drawn even where the material coverage is zero (e.g. moss gaps).
    if (g_View.debugShowBounds != 0u && hitCount > 0 && debugEdgeMax >= 0.92) {
        vec4 c = imageLoad(g_OutputColor, pixel);
        c.rgb = mix(c.rgb, vec3(0.0, 3.0, 3.0), 0.85); // Bright cyan HDR edge.
        imageStore(g_OutputColor, pixel, c);
        return;
    }
#endif

    if (totalCoverage <= 0.001) {
        return; // No decal actually shaded this pixel.
    }

    // --- Direct-color composite via albedo de-modulation (see this file's header comment). ---
    vec4 color = imageLoad(g_OutputColor, pixel);
    // Clamp floor keeps de-modulation stable where origAlbedo is dark (never divide by ~0).
    vec3 safeAlbedo = max(origAlbedo, vec3(0.06));
    vec3 illum = color.rgb / safeAlbedo;
    vec3 relitColor = illum * accAlbedo + accEmissive;
    color.rgb = relitColor;
    imageStore(g_OutputColor, pixel, color);

    // --- Write the decaled surface back into the GBuffer for the deferred lighting passes. ---
    imageStore(g_GBufferAlbedo, pixel, vec4(accAlbedo, 1.0));
    imageStore(g_GBufferRoughnessMetallic, pixel, vec4(accRough, accMetal, 0.0, 0.0));
    imageStore(g_GBufferNormal, pixel, vec4(OctEncode(normalize(accNormal)), 0.0, 0.0));
}
