#version 460
#extension GL_GOOGLE_include_directive : enable

// Stage 2/2 of renderer::BloomPass (Phase PP2, post-process stack roadmap): the "upsample +
// combine" half of the dual-filter bloom -- see BloomDownsample.comp's own comment for the
// technique this mirrors. Dispatched once per mip level from (mipCount - 2) down to 0 (mip
// (mipCount - 1), the smallest, needs no upsample step of its own -- it IS the downsample chain's
// smallest mip, sampled directly as this shader's `g_SmallerBlurred` input on its very first call).
// Each call's own output = this mip's own sharp "detail" (renderer::BloomPass's downsample chain,
// same mip index) + a 9-tap tent-filtered upsample of the smaller, already-blurred mip directly
// below it (renderer::BloomPass's upsample chain, mip N+1, or the downsample chain's own smallest
// mip on the first call) -- see renderer::BloomPass's own class comment for why this needs TWO
// separate mip chains (an in-place read-modify-write of one chain would read neighboring texels of
// the very same subresource this dispatch is writing, an unsynchronized hazard).
//
// The FINAL call (mip 0, `pc.isFinalMip != 0`) additionally generates this pipeline's Lens Flare
// (Ghosts + Halo), Anamorphic Lens Flare, and Lens Dirt -- 100% procedural, no texture asset for
// any of the four (per this project's own CLAUDE.md constraint), each sourced from
// renderer::BloomPass's own already-thresholded downsample chain (kFlareSourceMip) -- no separate
// bright-pass re-extraction -- and added on top of the plain bloom blend before writing the
// pipeline's final bloom+flare+dirt image, which renderer::PostProcessPass's own composite shader
// (PostProcessComposite.comp) samples and adds to the HDR scene color at the same exposed scale.

#include "include/math_utils.glsl"

layout(local_size_x = 8, local_size_y = 8) in;

layout(set = 0, binding = 0) uniform sampler2D g_SmallerBlurred; // Upsample chain mip N+1 (or downsample chain's smallest mip on the first call).
layout(set = 0, binding = 1) uniform sampler2D g_Detail;         // Downsample chain, same mip N as this dispatch's output.
layout(set = 0, binding = 2) uniform sampler2D g_FlareSource;    // Downsample chain, a fixed small/blurred mip -- only sampled when isFinalMip.
layout(rgba16f, set = 0, binding = 3) uniform writeonly image2D g_Output;

layout(push_constant) uniform PC {
    vec2 outputTexelSize;    // 1 / outputExtent, this dispatch's own mip.
    vec2 smallerMipTexelSize; // 1 / (outputExtent / 2), g_SmallerBlurred's own texel size.
    float upsampleRadius;    // Tent filter footprint scale, ~1.0 = exactly adjacent texels.
    uint isFinalMip;         // Nonzero on the mip-0 call: also generate flare/dirt below.
    // Lens Flare (radial ghosts) -- only meaningful when isFinalMip.
    float ghostIntensity;
    uint ghostCount;
    float ghostSpacing;
    // Halo (single fixed-radius ring, opposite side of center from the source) -- only meaningful
    // when isFinalMip.
    float haloIntensity;
    float haloWidth;
    // Per-ghost/halo chromatic shift (small per-channel radial UV split) -- only meaningful when
    // isFinalMip.
    float chromaticShift;
    // Anamorphic Lens Flare (horizontal streak) -- only meaningful when isFinalMip.
    float anamorphicIntensity;
    float anamorphicStretch; // UV-space half-width of the horizontal streak kernel.
    // Lens Dirt (procedural, no texture asset) -- only meaningful when isFinalMip.
    float dirtIntensity;
    float dirtScale;
} pc;

// Firefly/NaN guard -- see BloomDownsample.comp's own SanitizeHDR comment for the full rationale.
// This shader's own reads (g_SmallerBlurred/g_Detail/g_FlareSource) are a SEPARATE dispatch from
// BloomDownsample.comp's -- that shader's own guard does not cover these.
vec3 SanitizeHDR(vec3 c) {
    bvec3 bad = bvec3(isnan(c.r) || isinf(c.r), isnan(c.g) || isinf(c.g), isnan(c.b) || isinf(c.b));
    c = mix(c, vec3(0.0), bad);
    return min(c, vec3(50000.0));
}

vec3 UpsampleTent9(sampler2D tex, vec2 uv, vec2 texelSize, float radius) {
    vec4 o = texelSize.xyxy * vec4(1.0, 1.0, -1.0, 0.0) * radius;
    vec3 s  = SanitizeHDR(textureLod(tex, uv - o.xy, 0.0).rgb);
    s += SanitizeHDR(textureLod(tex, uv - o.wy, 0.0).rgb) * 2.0;
    s += SanitizeHDR(textureLod(tex, uv - o.zy, 0.0).rgb);
    s += SanitizeHDR(textureLod(tex, uv + o.zw, 0.0).rgb) * 2.0;
    s += SanitizeHDR(textureLod(tex, uv, 0.0).rgb) * 4.0;
    s += SanitizeHDR(textureLod(tex, uv + o.xw, 0.0).rgb) * 2.0;
    s += SanitizeHDR(textureLod(tex, uv + o.zy, 0.0).rgb);
    s += SanitizeHDR(textureLod(tex, uv + o.wy, 0.0).rgb) * 2.0;
    s += SanitizeHDR(textureLod(tex, uv + o.xy, 0.0).rgb);
    return s * (1.0 / 16.0);
}

// Cheap procedural hue cycle for each ghost's tint -- no palette texture, just a 3-phase cosine
// (Inigo Quilez's cosine-palette trick), producing a smooth rainbow-ish tint sweep across ghosts
// exactly like real camera-lens chromatic ghosting (each internal reflection shifts color
// slightly differently depending on coating/incidence angle).
vec3 GhostTint(float t) {
    return 0.5 + 0.5 * cos(6.28318 * (vec3(0.0, 0.33, 0.67) + t));
}

// 2-octave value noise (bilinear-interpolated Hash(vec2), from include/math_utils.glsl) used as a
// procedural lens-dirt mask -- smudges/specks of varying size, entirely generated, no texture
// asset, satisfying this project's "100% procedural, no texture input" constraint for Lens Dirt.
float ValueNoise(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    float a = Hash(i);
    float b = Hash(i + vec2(1.0, 0.0));
    float c = Hash(i + vec2(0.0, 1.0));
    float d = Hash(i + vec2(1.0, 1.0));
    vec2 u = f * f * (3.0 - 2.0 * f);
    return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

float LensDirtMask(vec2 uv, float scale) {
    float n = ValueNoise(uv * scale) * 0.6 + ValueNoise(uv * scale * 3.17) * 0.3 + ValueNoise(uv * scale * 7.53) * 0.1;
    // Sparse specks: only the upper tail of the noise distribution reads as a "dirt speck",
    // everything else stays near-transparent (dirt is sparse in reality, not a uniform haze).
    return smoothstep(0.55, 0.95, n);
}

// Samples `tex` 3 times, one per channel, each offset a small distance `shift` along `dir` (UV
// space) from `uv` -- a per-flare-sample analogue of PostProcessComposite.comp's own
// SampleWithChromaticAberration, but RADIAL along the ghost/halo chain's own line-through-center
// direction rather than the screen-center direction of the base scene capture (the two are only
// the same line for a ghost sitting exactly on it, which by construction they always are here).
// Real lens ghosting separates color slightly per internal reflection/incidence angle, so each
// individual ghost/halo sample gets its own small fringe rather than one uniform tint.
vec3 SampleChromaticShifted(sampler2D tex, vec2 uv, vec2 dir, float shift) {
    vec3 r = SanitizeHDR(textureLod(tex, clamp(uv + dir * shift, vec2(0.0), vec2(1.0)), 0.0).rgb);
    vec3 g = SanitizeHDR(textureLod(tex, clamp(uv, vec2(0.0), vec2(1.0)), 0.0).rgb);
    vec3 b = SanitizeHDR(textureLod(tex, clamp(uv - dir * shift, vec2(0.0), vec2(1.0)), 0.0).rgb);
    return vec3(r.r, g.g, b.b);
}

// Ghost chain: inverted/scaled resamples of the bright-pass source along the line through screen
// center. The sample position is first POINT-REFLECTED through the center (mirroredUV = 1 - uv --
// a real lens's internal reflections invert the image), then walked along the mirroredUV-to-center
// vector at a signed, scaled distance `t` per ghost that spans PAST the center (t outside [0, 1],
// not just between the mirrored point and the center) -- this is what actually produces the classic
// multi-ghost chain crossing through and beyond the center, landing ghosts back on the ORIGINAL
// side of the screen from the source, not merely between the source and the center.
vec3 SampleGhosts(vec2 uv) {
    vec2 mirroredUV = vec2(1.0) - uv;
    vec2 ghostVec = (vec2(0.5) - mirroredUV) * pc.ghostSpacing;
    float ghostVecLen = length(ghostVec);
    vec2 ghostDir = ghostVecLen > 1.0e-5 ? ghostVec / ghostVecLen : vec2(1.0, 0.0);

    vec3 result = vec3(0.0);
    for (uint i = 0u; i < pc.ghostCount; ++i) {
        float t01 = float(i) / max(float(pc.ghostCount - 1u), 1.0); // [0, 1] across the chain.
        float t = t01 * 2.2 - 0.6; // Signed/scaled: ~[-0.6, 1.6], deliberately spanning past both ends.
        vec2 ghostUV = mirroredUV + ghostVec * t;
        // Off-screen ghost samples are skipped entirely rather than fract()-wrapped (which would
        // smear the opposite screen edge in) or clamped (which would streak toward the border).
        if (any(lessThan(ghostUV, vec2(0.0))) || any(greaterThan(ghostUV, vec2(1.0)))) {
            continue;
        }
        float weight = 1.0 - abs(t01 - 0.5) * 1.6; // Falls off toward both ends of the ghost chain.
        weight = clamp(weight, 0.0, 1.0);
        vec3 sampleColor = SampleChromaticShifted(g_FlareSource, ghostUV, ghostDir, pc.chromaticShift);
        result += sampleColor * GhostTint(t01) * weight;
    }
    return result * pc.ghostIntensity;
}

// Halo: the other classic image-based lens-flare element alongside the ghost chain -- a single
// sample at a FIXED UV-space radius from screen center, on the line through center from the
// source, landing on the opposite side (a real lens forms this from a shallow-incidence internal
// reflection off the front element, always at roughly the same angular radius regardless of the
// source's own distance from center).
vec3 SampleHalo(vec2 uv) {
    vec2 toCenter = vec2(0.5) - uv;
    float toCenterLen = length(toCenter);
    // Degenerate at dead-center (source exactly at screen center): no well-defined halo direction,
    // and the term is negligible there regardless (a halo ring around a centered source is
    // rotationally symmetric, no single direction reads differently) -- pick an arbitrary axis.
    vec2 dir = toCenterLen > 1.0e-5 ? toCenter / toCenterLen : vec2(1.0, 0.0);
    vec2 haloUV = vec2(0.5) + dir * pc.haloWidth;
    if (any(lessThan(haloUV, vec2(0.0))) || any(greaterThan(haloUV, vec2(1.0)))) {
        return vec3(0.0); // Ring sample fell off-screen -- no wrap/clamp smear, same policy as ghosts.
    }
    return SampleChromaticShifted(g_FlareSource, haloUV, dir, pc.chromaticShift) * pc.haloIntensity;
}

vec3 SampleAnamorphicStreak(vec2 uv) {
    const int kTaps = 12;
    vec3 result = vec3(0.0);
    float totalWeight = 0.0;
    for (int i = -kTaps; i <= kTaps; ++i) {
        float t = float(i) / float(kTaps);
        float weight = 1.0 - abs(t);
        vec2 sampleUV = uv + vec2(t * pc.anamorphicStretch, 0.0);
        result += SanitizeHDR(textureLod(g_FlareSource, sampleUV, 0.0).rgb) * weight;
        totalWeight += weight;
    }
    result /= max(totalWeight, 1e-5);
    // Classic anamorphic-lens cyan/blue tint (horizontal cylindrical lens elements bias
    // transmission toward blue) -- procedural constant tint, not sampled from any asset.
    return result * vec3(0.6, 0.8, 1.4) * pc.anamorphicIntensity;
}

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 outputSize = ivec2(1.0 / pc.outputTexelSize.x, 1.0 / pc.outputTexelSize.y);
    if (pixel.x >= outputSize.x || pixel.y >= outputSize.y) {
        return;
    }

    vec2 uv = (vec2(pixel) + 0.5) * pc.outputTexelSize;

    vec3 detail = SanitizeHDR(textureLod(g_Detail, uv, 0.0).rgb);
    vec3 blurred = UpsampleTent9(g_SmallerBlurred, uv, pc.smallerMipTexelSize, pc.upsampleRadius);
    vec3 result = detail + blurred;

    if (pc.isFinalMip != 0u) {
        vec3 ghosts = SampleGhosts(uv);
        vec3 halo = SampleHalo(uv);
        vec3 streak = SampleAnamorphicStreak(uv);
        float dirt = LensDirtMask(uv, pc.dirtScale);
        // Lens Dirt only attenuates the flare/glare contribution (ghosts + halo + anamorphic
        // streak), never the base bloom bleed -- matches how real dirt/smudges on a lens element
        // only scatter light that grazes that specific optical path, not the whole glow halo.
        result += (ghosts + halo + streak) * mix(1.0, dirt, pc.dirtIntensity);
    }

    // Clamp the WRITTEN result into a finite, fp16-representable range before the store. This is the
    // real fix for the "bloom crushes the whole frame to black" bug (BLOOM_INTENSITY was force-
    // disabled as an interim workaround): the per-tap SanitizeHDR guards above only bound each
    // INDIVIDUAL input tap to 50000, but `result = detail + blurred` is a raw ADDITION of two such
    // full-magnitude terms (NOT a normalized average like the box/tent filters those guards were
    // sized for), so it reaches up to ~100000 -- well over fp16's 65504 max finite value -- and this
    // imageStore into the R16G16B16A16_SFLOAT bloom image would otherwise write +Inf. That +Inf then
    // flowed straight into PostProcessComposite.comp's final color (which additionally used to read
    // g_Bloom UN-sanitized), survived ACES tonemapping as NaN, and clamp(NaN, 0, 1) collapsed the
    // ENTIRE frame to black. Clamping at the store -- the exact point where the overflow occurs, and
    // downstream of every SanitizeHDR call -- guarantees the bloom image (and every intermediate
    // upsample mip, which all pass through this same line) is always finite. 65000 stays safely below
    // fp16 max so any tiny bilinear-filtered overshoot on the consuming side still cannot reach +Inf.
    vec3 finalColor = clamp(result, vec3(0.0), vec3(65000.0));
    imageStore(g_Output, pixel, vec4(finalColor, 1.0));
}
