// Phase 3 (UE5.8 parity roadmap): sun shadow lookup for the direct-lighting term below -- this
// shader's `diff` term was fully unshadowed before Phase 3 (only renderer::SurfaceCachePass's
// Surface Cache capture consumed the shadow map, feeding indirect lighting only). See
// shadow_sun_sampling.glsl's own header comment for the 3-level clipmap this samples.
#define SHADOW_ATLAS_SET 0
#define SHADOW_ATLAS_BINDING 15
#define SHADOW_PAGE_TABLE_SET 0
#define SHADOW_PAGE_TABLE_BINDING 16
#define SHADOW_FEEDBACK_SET 0
#define SHADOW_FEEDBACK_BINDING 17
#define SHADOW_SUN_LEVELS_SET 0
#define SHADOW_SUN_LEVELS_BINDING 18
#include "include/shadow_page_table.glsl"
#include "include/shadow_feedback.glsl"
#include "include/shadow_atlas_sampling.glsl"
#include "include/shadow_sun_sampling.glsl"

// Step 4 (Virtual Texturing / RVT-SVT parity roadmap): terrain/decal material detail sampled from
// renderer::VirtualTextureManager's page table + physical atlas, exactly like UE 5.8's Runtime
// Virtual Texture material expression -- see this shader's own Step 3 material-evaluation comment
// for where the sample is actually applied, and virtual_texture_lookup.glsl's header comment for
// why the coarse-mip-clamping fallback this needs costs zero extra instructions here.
#define VIRTUAL_TEXTURE_SET 0
#define PAGE_TABLE_BINDING 21
#define PHYSICAL_POOL_BINDING 22
#define VT_FEEDBACK_SET 0
#define VT_FEEDBACK_BINDING 23
#include "include/virtual_texture_feedback.glsl"
#include "include/virtual_texture_lookup.glsl"

// World-space volume renderer::VirtualTextureRenderPass's page table addresses (see that class's
// own VirtualTextureVolumeBounds) -- must match whatever bounds renderer::ClusterRenderPipeline
// initialized the SAME VirtualTextureRenderPass instance with, so a world position maps to the same
// virtual UV both a page-render and this consuming sample agree on.
layout(std140, set = 0, binding = 24) uniform VirtualTextureVolumeUBO {
    vec2 worldMinXZ;
    vec2 worldMaxXZ;
    float virtualTextureSize;
    float tileSize;
    float borderSize;
    float _pad0;
} g_VTVolume;

layout(std430, set = 0, binding = 0) readonly buffer ClusterCullMetadataSSBO {
    ClusterCullMetadata clusters[];
} g_Clusters;

// binding 1 == g_CompressedClusterPool, declared by cluster_vertex_decode.glsl.
// bindings 2-5 == g_HWClusterIDImage/g_HWTriangleIDImage/g_HWDepthTexture/g_SWVisBufferAtomic,
// declared by visbuffer_arbitration.glsl.

// rgba16f: linear HDR, matches renderer::ClusterResolvePass::kOutputColorFormat -- see that
// constant's own comment for why (unbounded MegaLights point-light radiance composited in later
// must not be hard-clipped by an 8-bit UNORM target before renderer::PostProcessPass ever runs).
layout(rgba16f, set = 0, binding = 6) uniform writeonly image2D g_OutputColor;

layout(std140, set = 0, binding = 7) uniform ResolveViewParamsUBO {
    mat4 viewProj;
    mat4 prevViewProj; // DEBUG_VIEW_MOTION_VECTORS' own reprojection -- see renderer::ClusterResolvePass::RecordResolve's comment.
    vec2 viewportSize;
    float _pad0;
    float _pad1;
    // Phase 3: sun direction (points FROM the light TOWARD the scene, matching renderer::
    // DirectionalLight's own convention) -- this shader's direct-lighting term now uses the SAME
    // sun direction the shadow was rendered from (see Step 3 below), instead of the pre-Phase-3
    // hardcoded, unrelated `vec3(0.5, 1.0, 0.5)` (a light/shadow direction mismatch would have
    // misaligned the lit/unlit transition against the shadow itself).
    vec3 sunDirection;
    float _pad2;
    // Substrate integration: the view direction Substrate's specular/Fresnel terms need (mirrors
    // ReflectionViewParamsUBO's/TransparentViewParamsUBO's own cameraPositionWorld field -- see
    // reflection_view_params.glsl) -- not previously threaded into this shader, since the
    // pre-Substrate shading here was pure Lambertian (no view-dependent term at all).
    vec3 cameraPositionWorld;
    float _pad3;
} g_ViewParams;

// Minimal GBuffer (renderer::ClusterResolvePass -- see its own class comment): written alongside
// g_OutputColor from the same per-pixel normal/albedo/depth this shader already reconstructs
// below, consumed by renderer::ScreenProbeGIPass and this shader's own DEBUG_VIEW_MOTION_VECTORS /
// DEBUG_VIEW_SPATIAL_PROBES modes.
layout(rg16f, set = 0, binding = 9) uniform writeonly image2D g_OutputNormal;
layout(r32f, set = 0, binding = 10) uniform writeonly image2D g_OutputDepth;
layout(rgba8, set = 0, binding = 11) uniform writeonly image2D g_OutputAlbedo;

// Same WPOGlobalsUBO renderer::ClusterRenderPipeline uploads once per frame and both rasterizers
// already bind (ClusterRaster.vert / ClusterSoftwareRaster.comp) -- this shader needs it too, to
// reapply the exact same sway deformation before re-deriving barycentric weights below (see this
// binding's own Init()-time comment in ClusterResolvePass::Init).
layout(std140, set = 0, binding = 12) uniform WPOGlobalsUBO {
    float globalTime;
    float _pad0;
    float _pad1;
    float _pad2;
} g_WPOGlobals;

// renderer::GenerateRandomMaterialTable()'s result (renderer/MaterialParameterTable.h), filled
// once at renderer::ClusterResolvePass::Init() -- see material_params.glsl's own comment.
layout(std430, set = 0, binding = 13) readonly buffer MaterialParamsSSBO {
    MaterialParams params[];
} g_MaterialParams;

// R=roughness, G=F0 luminance (renderer::ClusterResolvePass's own comment on why this is a separate
// image from g_OutputAlbedo rather than reusing that image's unused alpha channel). Read by
// ReflectionTrace.comp's VNDF importance sampling (R only).
layout(rg8, set = 0, binding = 14) uniform writeonly image2D g_OutputRoughnessMetallic;

// Substrate integration: this pixel's clamped materialID (0xFFFF sentinel = background/no
// geometry), letting ReflectionGather.comp/MegaLightsShade.comp (Phase S3) re-fetch the FULL Slab
// data straight from g_MaterialParams instead of this codebase growing the GBuffer with a field per
// Substrate parameter -- see the Substrate integration plan's own S2 rationale.
layout(r16ui, set = 0, binding = 25) uniform writeonly uimage2D g_OutputMaterialID;

// Per-entity self-rotation (dynamic primitive spin, added independently of the Phase 3 shadow
// bindings above) -- appended at 19/20 rather than renumbering the already-wired
// SHADOW_ATLAS/PAGE_TABLE/FEEDBACK/SUN_LEVELS bindings (15-18) declared earlier in this file.
layout(std430, set = 0, binding = 19) readonly buffer EntityTransformBuffer {
    EntityTransform entityTransforms[];
};

layout(std430, set = 0, binding = 20) readonly buffer EntityDataBuffer {
    EntityData entityData[];
};

