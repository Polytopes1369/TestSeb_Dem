bool DrawStringScaled(ivec2 pixel, ivec2 startPos, int chars[32], int len) {
    ivec2 diff = pixel - startPos;
    if (diff.x < 0 || diff.y < 0) return false;
    ivec2 local = diff / 2;
    if (local.y >= 5) return false;
    int charIdx = local.x / 6;
    if (charIdx >= len) return false;
    int localX = local.x % 6;
    if (localX == 5) return false;
    uint glyph = GetFontChar(chars[charIdx]);
    uint bitIdx = (local.y * 5) + localX;
    return ((glyph >> (24u - bitIdx)) & 1u) != 0u;
}
#endif

layout(local_size_x = 8, local_size_y = 8) in;

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    if (pixel.x >= int(g_ViewParams.viewportSize.x) || pixel.y >= int(g_ViewParams.viewportSize.y)) {
        return;
    }

    // --- Step 1: hardware vs software, whichever is nearer (see visbuffer_arbitration.glsl,
    // shared verbatim with ClusterShadingBinClassify.comp) ---
    VisibilityArbitration vis = ArbitrateVisibility(pixel);
    bool hwWins = vis.hwWins;
    uint clusterSlotIndex = vis.clusterSlotIndex;
    uint triangleOrdinal = vis.triangleOrdinal;
    bool hasAnyData = vis.hasAnyData;
    float hwDepth = vis.hwDepth;
    float swDepth = vis.swDepth;

    vec3 finalColor = vec3(0.05, 0.05, 0.1);
    // GBuffer defaults for a background (no-geometry) pixel: depth = 0.0 (the far plane, reversed-Z
    // -- see maths::mat4::PerspectiveVulkan's own comment, "LARGER is nearer" now) is renderer::
    // ScreenProbeGIPass's validity sentinel for "do not place/gather a probe against this pixel" --
    // mirrors renderer::SurfaceCachePass's own worldPosClear alpha=0 "never captured" convention.
    float gbufferDepth = 0.0;
    vec3 gbufferNormal = vec3(0.0, 1.0, 0.0);
    vec3 gbufferAlbedo = vec3(0.0);
    vec2 gbufferRoughnessMetallic = vec2(0.0, 0.0);
    // Substrate integration: sentinel materialID for a background pixel -- lets ReflectionGather.comp
    // / MegaLightsShade.comp (Phase S3) tell "no material here" apart from a real slot 0 lookup
    // without a second depth check duplicated in every consumer.
    uint gbufferMaterialID = 0xFFFFu;

    if (hasAnyData) {
        // --- Step 2: re-fetch the winning triangle's 3 vertices and reconstruct barycentrics ---
        ClusterCullMetadata cluster = g_Clusters.clusters[clusterSlotIndex];
        uint physicalPageIndex = cluster.vertexOffset / CLUSTER_MAX_VERTICES;
        uint pageByteBase = physicalPageIndex * CLUSTER_PAGE_SIZE_BYTES;

        uint i0 = ClusterLoadByte(pageByteBase + CLUSTER_INDICES_BASE_BYTES + triangleOrdinal * 3u + 0u);
        uint i1 = ClusterLoadByte(pageByteBase + CLUSTER_INDICES_BASE_BYTES + triangleOrdinal * 3u + 1u);
        uint i2 = ClusterLoadByte(pageByteBase + CLUSTER_INDICES_BASE_BYTES + triangleOrdinal * 3u + 2u);

        vec3 p0 = DecodeClusterPosition(pageByteBase, i0, cluster.boundsMin, cluster.boundsMax);
        vec3 p1 = DecodeClusterPosition(pageByteBase, i1, cluster.boundsMin, cluster.boundsMax);
        vec3 p2 = DecodeClusterPosition(pageByteBase, i2, cluster.boundsMin, cluster.boundsMax);

        // Apply entity self-rotation
        EntityData ed = entityData[cluster.entityID];
        EntityTransform xform = entityTransforms[ed.meshID];
        mat3 rotation = mat3(xform.rotation);

        p0 = xform.center + rotation * (p0 - xform.center);
        p1 = xform.center + rotation * (p1 - xform.center);
        p2 = xform.center + rotation * (p2 - xform.center);

#ifdef _DEBUG
        // Pre-deformation copies, kept ONLY in Debug builds -- DEBUG_VIEW_NANITE_WPO (below) needs
        // both the deformed and undeformed position at this pixel to visualize actual per-pixel WPO
        // displacement magnitude; Release has no such view mode and pays zero cost for these.
        vec3 p0Undeformed = p0;
        vec3 p1Undeformed = p1;
        vec3 p2Undeformed = p2;
#endif

        // Reapply the exact same WPO sway both rasterizers already applied to the vertices they
        // actually drew (ClusterRaster.vert / cluster_software_raster_core.glsl) -- without this,
        // any swaying cluster's re-projected screen-space triangle here disagrees with the one that
        // determined pixel coverage, corrupting the reconstructed barycentric weights (and, at a
        // swaying cluster's own silhouette/boundary, contributing to depth/position mismatches).
        p0 = ApplyWPODeformation(p0, cluster.clusterID, cluster.maxWPOAmplitude, g_WPOGlobals.globalTime);
        p1 = ApplyWPODeformation(p1, cluster.clusterID, cluster.maxWPOAmplitude, g_WPOGlobals.globalTime);
        p2 = ApplyWPODeformation(p2, cluster.clusterID, cluster.maxWPOAmplitude, g_WPOGlobals.globalTime);

        vec3 n0 = rotation * DecodeClusterNormal(pageByteBase, i0);
        vec3 n1 = rotation * DecodeClusterNormal(pageByteBase, i1);
        vec3 n2 = rotation * DecodeClusterNormal(pageByteBase, i2);
        vec2 uv0 = DecodeClusterUV(pageByteBase, i0);
        vec2 uv1 = DecodeClusterUV(pageByteBase, i1);
        vec2 uv2 = DecodeClusterUV(pageByteBase, i2);

        vec4 clip0 = g_ViewParams.viewProj * vec4(p0, 1.0);
        vec4 clip1 = g_ViewParams.viewProj * vec4(p1, 1.0);
        vec4 clip2 = g_ViewParams.viewProj * vec4(p2, 1.0);

        vec2 screen0 = (clip0.xy / clip0.w * 0.5 + 0.5) * g_ViewParams.viewportSize;
        vec2 screen1 = (clip1.xy / clip1.w * 0.5 + 0.5) * g_ViewParams.viewportSize;
        vec2 screen2 = (clip2.xy / clip2.w * 0.5 + 0.5) * g_ViewParams.viewportSize;

        vec2 pixelCenter = vec2(pixel) + 0.5;

        float area2 = EdgeFunction(screen0, screen1, screen2);
        float invArea2 = (abs(area2) > 1.0e-8) ? (1.0 / area2) : 0.0;

        // Screen-space-linear barycentric weights (not yet perspective-correct).
        float w0 = EdgeFunction(screen1, screen2, pixelCenter) * invArea2;
        float w1 = EdgeFunction(screen2, screen0, pixelCenter) * invArea2;
        float w2 = EdgeFunction(screen0, screen1, pixelCenter) * invArea2;

        // Perspective correction: screen-space-linear weights interpolate attributes incorrectly under
        // perspective projection (unlike NDC depth itself, which the rasterizer already relies on
        // being screen-linear) -- dividing each weight by its vertex's clip.w and renormalizing
        // recovers the perspective-correct weights standard rasterizers apply to varyings.
        float invW0 = 1.0 / clip0.w;
        float invW1 = 1.0 / clip1.w;
        float invW2 = 1.0 / clip2.w;
        float interpInvW = w0 * invW0 + w1 * invW1 + w2 * invW2;
        float perspNorm = (abs(interpInvW) > 1.0e-8) ? (1.0 / interpInvW) : 0.0;
        float pw0 = w0 * invW0 * perspNorm;
        float pw1 = w1 * invW1 * perspNorm;
        float pw2 = w2 * invW2 * perspNorm;

        vec3 normal = normalize(pw0 * n0 + pw1 * n1 + pw2 * n2);
        vec2 uv = pw0 * uv0 + pw1 * uv1 + pw2 * uv2;
        vec3 worldPos = pw0 * p0 + pw1 * p1 + pw2 * p2;

        // --- Step 3: material evaluation (see the class comment above) ---
        // g_ViewParams.sunDirection points FROM the light TOWARD the scene (renderer::
        // DirectionalLight's own convention) -- negate for the surface-to-light direction
        // Lambertian shading needs, matching SurfaceCacheCapture.frag's identical convention.
        vec3 lightDir = normalize(-g_ViewParams.sunDirection);
        float diff = max(dot(normal, lightDir), 0.0);
        // Phase 3: shadow visibility for the sun, sampled from renderer::VirtualShadowMapPass's
        // 3-level clipmap -- only the direct `diff` term is shadowed, not the ambient/fill term
        // below (a flat 0.15 ambient approximation has no directional occluder to speak of).
        float sunVisibility = (diff > 0.0) ? SampleSunShadowVSM(worldPos) : 1.0;
        // Substrate integration: the view direction EvaluateSubstrateMaterial's specular/Fresnel
        // terms need -- see this file's own ResolveViewParamsUBO.cameraPositionWorld comment.
        vec3 viewDir = normalize(g_ViewParams.cameraPositionWorld - worldPos);

        // Hash by cluster.clusterID (the DAG's own dense, per-file-unique numbering, assigned once
        // at cache-build time -- see geometry::ClusterIndexEntry::clusterID), NOT clusterSlotIndex:
        // clusterSlotIndex is this cluster's index into THIS FRAME's candidate metadata buffer,
        // assigned by ClusterLODCompact.comp's atomicAdd(g_CandidateCount.count, ...) -- parallel
        // GPU invocations' atomic increments do not resolve in a fixed order frame to frame, so the
        // same physical cluster can land in a DIFFERENT slot every frame even with a static camera
        // and an unchanged candidate set. Hashing that slot directly made every cluster's procedural
        // color re-randomize every frame -- visually indistinguishable from genuine z-fighting at a
        // cluster boundary, since two adjacent clusters' colors were both flickering independently.
        // clusterID has no such instability: it is fixed at cache-build time and never reassigned.
        uint hashed = HashID(cluster.clusterID);
        float hue = float(hashed) / 4294967295.0;

        // Real Substrate material lookup (see this file's Step 3 class comment) -- clamped against
        // MATERIAL_TABLE_SIZE (material_params.glsl) so an out-of-range materialID safely falls
        // back to the table's last slot instead of indexing past g_MaterialParams' real allocation.
        uint materialSlot = min(cluster.materialID, MATERIAL_TABLE_SIZE - 1u);
        MaterialParams mat = g_MaterialParams.params[materialSlot];
        gbufferMaterialID = materialSlot;

        // Step 4: Runtime Virtual Texture detail multiply -- worldPos.xz mapped into the VT volume's
        // [0,1]^2 UV space, sampled through the page table (miss-detection + coarse-mip fallback
        // entirely inside SampleVirtualTextureLOD, see that function's own comment). Every physical
        // pool slot is guaranteed cleared to opaque white at VirtualTextureManager::Init() time (see
        // that function's own comment), so this multiply is a mathematical no-op -- zero visual
        // change to the existing procedural material -- until real tile content has actually been
        // baked (renderer::VirtualTextureRenderPass) or streamed in (renderer::
        // VirtualTextureStreamingCoordinator) for the page(s) this pixel falls into.
        //
        // Uses the explicit-LOD entry point rather than screen-space-derivative-based
        // TranslateVirtualTextureUV/SampleVirtualTextureGrad: dFdx/dFdy are not natively available
        // in a compute shader at all (would need GL_NV_compute_shader_derivatives, an NVIDIA-only
        // extension unsupported on AMD/Intel -- unacceptable for this engine's general Windows x64
        // target, see CLAUDE.md's own hardware scope). `perspNorm` (already computed above for
        // perspective-correct barycentric interpolation) IS this pixel's own perspective-correct
        // interpolated clip.w, i.e. its view-space distance from the camera -- see
        // ClusterResolveBinned.comp's own identical use of this same heuristic for the full
        // derivation and why it is portable across every dispatch topology.
        const float kVTReferenceDistance = 2.0;
        float vtLod = log2(max(perspNorm, 0.01) / kVTReferenceDistance);
        vec2 vtUV = (worldPos.xz - g_VTVolume.worldMinXZ) / (g_VTVolume.worldMaxXZ - g_VTVolume.worldMinXZ);
        vec3 vtAlbedo = SampleVirtualTextureLOD(0u, vtUV, vtLod, g_VTVolume.virtualTextureSize, g_VTVolume.tileSize, g_VTVolume.borderSize).rgb;
        mat.base.diffuseAlbedo *= vtAlbedo;

        // Substrate: full Slab BSDF response (diffuse + anisotropic specular + second lobe/Haze +
        // fuzz, vertically layered with the Top slab if any -- see substrate_bsdf.glsl's own
        // EvaluateSubstrateMaterial comment) to the sun's direction, shadowed by sunVisibility. The
        // flat 0.15 ambient/fill term (unchanged from the pre-Substrate shader) stays a plain
        // albedo tint -- it has no single light direction for a BRDF to respond to, exactly like the
        // pre-Substrate code's own identical simplification.
        vec3 directResponse = EvaluateSubstrateMaterial(mat, normal, viewDir, lightDir);
        finalColor = mat.base.diffuseAlbedo * 0.15 + directResponse * sunVisibility + EvaluateSubstrateEmissive(mat);

        // GBuffer capture (renderer::ClusterResolvePass's new outputs -- see this file's own
        // binding comment): the same winning (hw-vs-sw arbitrated) depth already used to pick
        // clusterSlotIndex/triangleOrdinal above, plus the reconstructed normal/albedo/material.
        gbufferDepth = hwWins ? hwDepth : swDepth;
        gbufferNormal = normal;
        gbufferAlbedo = mat.base.diffuseAlbedo;
        // G channel: F0 luminance (generalizes the old plain "metallic" scalar -- a metal's F0 IS
        // its albedo so this reads high for metals and ~0.04 for dielectrics, same shape the old
        // channel had) -- kept only for ReflectionTrace.comp's roughness read (R channel) and any
        // future debug consumer; Phase S3's Substrate-aware passes read the real Slab data straight
        // from g_MaterialParams via gbufferMaterialID instead of this approximation.
        gbufferRoughnessMetallic = vec2(mat.base.roughness, dot(mat.base.f0, vec3(0.2126, 0.7152, 0.0722)));

        // Opacity-mask soft edge feathering: the hard cutout already happened upstream
        // (ClusterRaster.frag's discard / ClusterSoftwareRaster.comp's skipped atomic write), so
        // only pixels whose alpha already cleared that cutoff ever reach this point -- blending
        // toward the background color based on how far above the cutoff this pixel's alpha sits
        // softens what would otherwise be a hard-edged foliage silhouette. A no-op for any
        // non-masked cluster (SampleMaskAlpha returns 1.0 for the sentinel, past both smoothstep
        // edges).
        if (cluster.maskTextureIndex != 0xFFFFFFFFu) {
            float maskAlpha = SampleMaskAlpha(cluster.maskTextureIndex, uv);
            float edgeBlend = smoothstep(0.5, 0.75, maskAlpha);
            finalColor = mix(vec3(0.05, 0.05, 0.1), finalColor, edgeBlend);
        }

#ifdef _DEBUG
        if (pc.viewMode == 1) { // DEBUG_VIEW_NANITE_TRIANGLES
            // cluster.clusterID, not clusterSlotIndex -- see the default-shading hue comment above
            // for why the slot index flickers frame to frame; a triangle-boundary visualization
            // needs to be temporally stable to actually be useful for inspecting triangle density.
            uint hashedTri = HashID(cluster.clusterID * 1337u + triangleOrdinal);
            finalColor = HsvToRgb(vec3(float(hashedTri) / 4294967295.0, 0.8, 0.8));
        } else if (pc.viewMode == 2) { // DEBUG_VIEW_NANITE_CLUSTERS
            finalColor = HsvToRgb(vec3(hue, 0.8, 0.8));
        } else if (pc.viewMode == 3) { // DEBUG_VIEW_NANITE_INSTANCES
            // Hash-color by the owning entity's meshID (ClusterCullMetadata::entityID) -- same
            // technique as DEBUG_VIEW_NANITE_CLUSTERS above, but grouping every cluster belonging
            // to the same entity under one color instead of coloring per-cluster.
            uint hashedEntity = HashID(cluster.entityID);
            finalColor = HsvToRgb(vec3(float(hashedEntity) / 4294967295.0, 0.8, 0.8));
        } else if (pc.viewMode == 4) { // DEBUG_VIEW_NANITE_PRIMITIVES
            // Triangle-density heat gradient: cluster.indexCount / 3 is this cluster's triangle
            // count, capped at CLUSTER_MAX_INDICES/3 (128, see ClusterFormat.h's kMaxClusterTriangles)
            // -- a standard cold (sparse) -> hot (dense) 3-stop ramp.
            float density = clamp(float(cluster.indexCount) / 384.0, 0.0, 1.0);
            vec3 cold = vec3(0.0, 0.0, 1.0);
            vec3 mid = vec3(0.0, 1.0, 0.0);
            vec3 hot = vec3(1.0, 0.0, 0.0);
            finalColor = (density < 0.5) ? mix(cold, mid, density * 2.0) : mix(mid, hot, (density - 0.5) * 2.0);
        } else if (pc.viewMode == 5) { // DEBUG_VIEW_NANITE_SHADING_BINS
            // Hash-color by cluster.materialID -- every cluster sharing a material shares a color,
            // visualizing the actual grouping a future shading-bin classification pass (sorting
            // VisBuffer pixels by material for warp-coherent shading -- not yet implemented, see
            // this file's own class comment) would bin together. Distinct from
            // DEBUG_VIEW_NANITE_CLUSTERS (per-cluster) and DEBUG_VIEW_NANITE_INSTANCES (per-entity).
            uint hashedBin = HashID(cluster.materialID);
            finalColor = HsvToRgb(vec3(float(hashedBin) / 4294967295.0, 0.8, 0.8));
        } else if (pc.viewMode == 6) { // DEBUG_VIEW_NANITE_RASTER_BINS
            // Hash-color by a bucketed clusterSlotIndex -- visualizes rasterization submission
            // batching (nearby slot indices, likely dispatched/drawn close together, share a color).
            const uint kRasterBinSize = 64u;
            uint hashedBin = HashID(clusterSlotIndex / kRasterBinSize);
            finalColor = HsvToRgb(vec3(float(hashedBin) / 4294967295.0, 0.8, 0.8));
        } else if (pc.viewMode == 7) { // DEBUG_VIEW_NANITE_WPO
            // Actual per-pixel WPO displacement magnitude: the same perspective-correct barycentric
            // weights (pw0/pw1/pw2, computed above) applied to both the deformed (p0/p1/p2) and
            // undeformed (p0Undeformed/p1Undeformed/p2Undeformed) vertex positions, so this reads
            // the REAL resolved displacement at this exact pixel, not merely the cluster's
            // worst-case bound (cluster.maxWPOAmplitude) used only to normalize the color ramp.
            vec3 deformedPos = pw0 * p0 + pw1 * p1 + pw2 * p2;
            vec3 undeformedPos = pw0 * p0Undeformed + pw1 * p1Undeformed + pw2 * p2Undeformed;
            float displacement = length(deformedPos - undeformedPos);
            float normalizedDisplacement = (cluster.maxWPOAmplitude > 1.0e-6)
                ? clamp(displacement / cluster.maxWPOAmplitude, 0.0, 1.0) : 0.0;
            finalColor = mix(vec3(0.0, 0.0, 0.2), vec3(1.0, 0.35, 0.0), normalizedDisplacement);
        } else if (pc.viewMode == 8) { // DEBUG_VIEW_OVERDRAWS
            if (hwWins) finalColor = vec3(0.0, 1.0, 0.0);
            else finalColor = vec3(0.0, 0.0, 1.0);
        } else if (pc.viewMode == 10) { // DEBUG_VIEW_DEPTH
            // 1.0 - d: reversed-Z means d=1 is near/d=0 is far now, but this visualization's own
            // "near reads dark, far reads bright" intent (unchanged since before this codebase's
            // reversed-Z conversion) still wants the ORIGINAL [0,1]-non-reversed sense fed to the
            // display curve below.
            float d = 1.0 - (hwWins ? hwDepth : swDepth);
            finalColor = vec3(pow(d, 0.2));
        } else if (pc.viewMode == 11) { // DEBUG_VIEW_NORMALS
            finalColor = normal * 0.5 + 0.5;
        } else if (pc.viewMode == 12) { // DEBUG_VIEW_MOTION_VECTORS
            // Reconstruct this pixel's world position from its own NDC + the winning depth (the
            // exact same unproject renderer::ScreenProbeGIPass's temporal pass performs for a
            // probe's world position), then reproject with the PREVIOUS frame's viewProj to see
            // where this same (static -- see ClusterRenderPipeline.h's own "Entity self-rotation"
            // scope note) world point was on screen last frame.
            vec2 ndcXY = (pixelCenter / g_ViewParams.viewportSize) * 2.0 - 1.0;
            vec4 clipPos = vec4(ndcXY, gbufferDepth, 1.0);
            vec4 worldPos4 = inverse(g_ViewParams.viewProj) * clipPos;
            vec3 worldPos = worldPos4.xyz / worldPos4.w;

            vec4 prevClip = g_ViewParams.prevViewProj * vec4(worldPos, 1.0);
            vec2 prevScreen = (prevClip.xy / prevClip.w * 0.5 + 0.5) * g_ViewParams.viewportSize;
            vec2 motionVector = pixelCenter - prevScreen;

            // Centered-at-0.5 visualization: a static camera reads as flat mid-grey, motion shows
            // as a colored gradient whose hue/brightness encodes direction/magnitude.
            finalColor = vec3(motionVector * 0.05 + 0.5, 0.5);
        } else if (pc.viewMode == 14) {
            // DEBUG_VIEW_SPATIAL_PROBES: leave finalColor as normally shaded here --
            // renderer::GICompositePass's own compute pass (GIComposite.comp) overwrites the final
            // image with a World Probe grid visualization when this view mode is active (see that
            // shader's own viewMode==14 branch); this branch only exists to opt out of the
            // "unhandled view mode" magenta placeholder below.
        } else if (pc.viewMode == 15) { // DEBUG_VIEW_SHADOW_CASCADES
            // Color-codes which sun clipmap level (renderer::VirtualShadowMapPass, Phase 3) covers
            // this pixel's world position -- red=level 0 (finest), green=level 1, blue=level 2
            // (coarsest) -- at full brightness if that level's covering page is already resident,
            // dimmed to a third if not (a miss was just requested by this pixel's own
            // SampleSunShadowVSM call above -- see that function's request+fallback comment). This
            // mirrors the exact same level/page derivation SampleSunShadowVSM performs internally,
            // just for visualization instead of a shadow factor.
            const vec3 kLevelColors[SHADOW_SUN_LEVEL_COUNT] = vec3[SHADOW_SUN_LEVEL_COUNT](
                vec3(1.0, 0.2, 0.2), vec3(0.2, 1.0, 0.2), vec3(0.2, 0.4, 1.0));
            finalColor = vec3(0.5); // No level covers this point -- should not normally happen.
            for (uint level = 0u; level < SHADOW_SUN_LEVEL_COUNT; ++level) {
                vec4 dbgClip = g_ShadowSunLevels.viewProj[level] * vec4(worldPos, 1.0);
                vec3 dbgNdc = dbgClip.xyz / dbgClip.w;
                if (dbgNdc.x < -1.0 || dbgNdc.x > 1.0 || dbgNdc.y < -1.0 || dbgNdc.y > 1.0 || dbgNdc.z < 0.0 || dbgNdc.z > 1.0) {
                    continue;
                }
                vec2 dbgPagePos = clamp((dbgNdc.xy * 0.5 + 0.5) * float(SHADOW_PAGES_PER_AXIS),
                    vec2(0.0), vec2(float(SHADOW_PAGES_PER_AXIS) - 1.0e-4));
                uvec2 dbgPageCoord = uvec2(floor(dbgPagePos));
                uint dbgLogicalPageID = ShadowLogicalPageID(level, dbgPageCoord);
                bool dbgResident = IsShadowPageResident(dbgLogicalPageID);
                finalColor = kLevelColors[level] * (dbgResident ? 1.0 : 0.35);
                break;
            }
        } else if (pc.viewMode == 16) { // DEBUG_VIEW_SUBSTRATE_SLABS
            // Color-codes this pixel's Top slab (Substrate vertical layering): grey = no top slab
            // (mat.topWeight == 0.0, the common case), blue-tinted = Clear Coat (top.f0 clamped to
            // the dielectric ~0.04 baseline, no fuzz), orange-tinted = Fuzz/Cloth (top.fuzzAmount >
            // 0.0) -- brightness scaled by topWeight (coverage) so a barely-there coat reads dim and
            // a heavy coat reads bright. Distinguishes the two ONLY by fuzzAmount since both
            // categories GenerateRandomMaterialTable emits share the same dielectric top.f0 (see
            // that function's own Clear Coat / Fuzz branches) -- fuzzAmount is the one field that
            // actually differs between them.
            if (mat.topWeight <= 0.0) {
                finalColor = vec3(0.4, 0.4, 0.4);
            } else if (mat.top.fuzzAmount > 0.0) {
                finalColor = vec3(0.9, 0.55, 0.1) * mat.topWeight;
            } else {
                finalColor = vec3(0.15, 0.45, 0.95) * mat.topWeight;
            }
        } else if (pc.viewMode != 0 && pc.viewMode != 9 && pc.viewMode != 13) {
            // Placeholders (Global SDF / Lumen visualizations not implemented by this shader).
            finalColor = vec3(1.0, 0.0, 1.0);
        }
#endif
    } else {
#ifdef _DEBUG
        if (pc.viewMode == 10) { // DEBUG_VIEW_DEPTH
            // For depth view, empty background should render as white/1.0
            finalColor = vec3(1.0);
        } else if (pc.viewMode == 12 || pc.viewMode == 14) {
            // No geometry here: zero motion / no probe contribution -- leave finalColor at the
            // plain background color instead of the "unhandled view mode" magenta placeholder.
        } else if (pc.viewMode == 15) {
            // DEBUG_VIEW_SHADOW_CASCADES: no world position exists for a background pixel -- leave
            // finalColor at the plain background color, matching MOTION_VECTORS/SPATIAL_PROBES above.
        } else if (pc.viewMode == 3 || pc.viewMode == 4 || pc.viewMode == 5 || pc.viewMode == 6 || pc.viewMode == 7 || pc.viewMode == 16) {
            // NANITE_INSTANCES/PRIMITIVES/SHADING_BINS/RASTER_BINS/WPO/SUBSTRATE_SLABS: all per-cluster
            // visualizations with nothing meaningful to show on a no-geometry pixel -- leave
            // finalColor at the plain background color, matching NANITE_TRIANGLES/CLUSTERS above.
        } else if (pc.viewMode != 0 && pc.viewMode != 1 && pc.viewMode != 2 && pc.viewMode != 8 && pc.viewMode != 11) {
            // For Lumen / SDF placeholders, render the placeholder color even on background
            finalColor = vec3(1.0, 0.0, 1.0);
        }
#endif
    }

    imageStore(g_OutputNormal, pixel, vec4(OctEncode(gbufferNormal), 0.0, 0.0));
    imageStore(g_OutputDepth, pixel, vec4(gbufferDepth, 0.0, 0.0, 0.0));
    imageStore(g_OutputAlbedo, pixel, vec4(gbufferAlbedo, 1.0));
    imageStore(g_OutputRoughnessMetallic, pixel, vec4(gbufferRoughnessMetallic, 0.0, 0.0));
    imageStore(g_OutputMaterialID, pixel, uvec4(gbufferMaterialID, 0u, 0u, 0u));

#ifdef _DEBUG
    ivec2 uiPixel = pixel / 2;
    ivec2 uiRes = ivec2(g_ViewParams.viewportSize) / 2;
    int chars[32];
    int len = 0;
    
    if (pc.viewMode == 0) {
        chars[0]=78; chars[1]=79; chars[2]=82; chars[3]=77; chars[4]=65; chars[5]=76; len=6;
    } else if (pc.viewMode == 1) {
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=84; chars[8]=82; chars[9]=73; chars[10]=65; chars[11]=78; chars[12]=71; chars[13]=76; chars[14]=69; chars[15]=83; len=16;
    } else if (pc.viewMode == 2) {
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=67; chars[8]=76; chars[9]=85; chars[10]=83; chars[11]=84; chars[12]=69; chars[13]=82; chars[14]=83; len=15;
    } else if (pc.viewMode == 3) { // "NANITE INSTANCES"
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=73; chars[8]=78; chars[9]=83; chars[10]=84; chars[11]=65; chars[12]=78; chars[13]=67; chars[14]=69; chars[15]=83; len=16;
    } else if (pc.viewMode == 4) { // "NANITE PRIMITIVES"
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=80; chars[8]=82; chars[9]=73; chars[10]=77; chars[11]=73; chars[12]=84; chars[13]=73; chars[14]=86; chars[15]=69; chars[16]=83; len=17;
    } else if (pc.viewMode == 5) { // "NANITE SHADING BINS"
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=83; chars[8]=72; chars[9]=65; chars[10]=68; chars[11]=73; chars[12]=78; chars[13]=71; chars[14]=32; chars[15]=66; chars[16]=73; chars[17]=78; chars[18]=83; len=19;
    } else if (pc.viewMode == 6) { // "NANITE RASTER BINS"
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=82; chars[8]=65; chars[9]=83; chars[10]=84; chars[11]=69; chars[12]=82; chars[13]=32; chars[14]=66; chars[15]=73; chars[16]=78; chars[17]=83; len=18;
    } else if (pc.viewMode == 7) { // "NANITE WPO"
        chars[0]=78; chars[1]=65; chars[2]=78; chars[3]=73; chars[4]=84; chars[5]=69; chars[6]=32; chars[7]=87; chars[8]=80; chars[9]=79; len=10;
    } else if (pc.viewMode == 8) {
        chars[0]=79; chars[1]=86; chars[2]=69; chars[3]=82; chars[4]=68; chars[5]=82; chars[6]=65; chars[7]=87; chars[8]=83; len=9;
    } else if (pc.viewMode == 10) {
        chars[0]=68; chars[1]=69; chars[2]=80; chars[3]=84; chars[4]=72; len=5;
    } else if (pc.viewMode == 11) {
        chars[0]=78; chars[1]=79; chars[2]=82; chars[3]=77; chars[4]=65; chars[5]=76; chars[6]=83; len=7;
    } else if (pc.viewMode == 13) {
        chars[0]=76; chars[1]=85; chars[2]=77; chars[3]=69; chars[4]=78; len=5;
    } else if (pc.viewMode == 12) {
        chars[0]=77; chars[1]=79; chars[2]=84; chars[3]=73; chars[4]=79; chars[5]=78; chars[6]=32; chars[7]=86; chars[8]=69; chars[9]=67; chars[10]=84; chars[11]=79; chars[12]=82; chars[13]=83; len=14;
    } else if (pc.viewMode == 9) {
        chars[0]=71; chars[1]=76; chars[2]=79; chars[3]=66; chars[4]=65; chars[5]=76; chars[6]=32; chars[7]=83; chars[8]=68; chars[9]=70; len=10;
    } else if (pc.viewMode == 14) {
        chars[0]=83; chars[1]=80; chars[2]=65; chars[3]=84; chars[4]=73; chars[5]=65; chars[6]=76; chars[7]=32; chars[8]=80; chars[9]=82; chars[10]=79; chars[11]=66; chars[12]=69; chars[13]=83; len=14;
    } else if (pc.viewMode == 15) { // "SHADOW CASCADES"
        chars[0]=83; chars[1]=72; chars[2]=65; chars[3]=68; chars[4]=79; chars[5]=87; chars[6]=32; chars[7]=67; chars[8]=65; chars[9]=83; chars[10]=67; chars[11]=65; chars[12]=68; chars[13]=69; chars[14]=83; len=15;
    } else if (pc.viewMode == 16) { // "SUBSTRATE SLABS"
        chars[0]=83; chars[1]=85; chars[2]=66; chars[3]=83; chars[4]=84; chars[5]=82; chars[6]=65; chars[7]=84; chars[8]=69; chars[9]=32; chars[10]=83; chars[11]=76; chars[12]=65; chars[13]=66; chars[14]=83; len=15;
    }

    if (len > 0) {
        int strWidth = len * 12;
        ivec2 startPos = ivec2(uiRes.x - strWidth - 8, uiRes.y - 10 - 8);
        
        // Restrict outline / text processing to bounding box plus padding for performance
        if (uiPixel.x >= startPos.x - 4 && uiPixel.x <= startPos.x + strWidth + 3 &&
            uiPixel.y >= startPos.y - 4 && uiPixel.y <= startPos.y + 13) {
            
            bool isText = DrawStringScaled(uiPixel, startPos, chars, len);
            if (isText) {
                finalColor = vec3(1.0, 1.0, 1.0); // White text
            } else {
                bool isOutline = false;
                for (int dy = -2; dy <= 2; ++dy) {
                    for (int dx = -2; dx <= 2; ++dx) {
                        if (dx == 0 && dy == 0) continue;
                        if (dx * dx + dy * dy <= 5) {
                            if (DrawStringScaled(uiPixel + ivec2(dx, dy), startPos, chars, len)) {
                                isOutline = true;
                                break;
                            }
                        }
                    }
                    if (isOutline) break;
                }
                if (isOutline) {
                    finalColor = vec3(0.0, 0.0, 0.0); // Black outline
                }
            }
        }
    }
#endif

    imageStore(g_OutputColor, pixel, vec4(finalColor, 1.0));
}
